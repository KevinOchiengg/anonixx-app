{
  "expo": {
    "name": "Anonixx",
    "slug": "anonixx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "anonixx",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f18"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonixx.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSMicrophoneUsageDescription": "Anonixx needs your microphone for anonymous voice and video calls.",
        "NSCameraUsageDescription": "Anonixx needs your camera for anonymous video calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f18"
      },
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "RECORD_AUDIO",
        "CAMERA"
      ],
      "package": "com.anonixx.app",
      "navigationBarColor": "#151924",
      "navigationBarStyle": "dark",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "anonixx",
              "host": "drop"
            },
            {
              "scheme": "anonixx",
              "host": "confession"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Anonixx",
      "shortName": "Anonixx",
      "description": "Anonymous emotion. Structured connection.",
      "themeColor": "#FF634A",
      "backgroundColor": "#0b0f18"
    },
    "plugins": ["expo-asset", "expo-video", "expo-navigation-bar"],
    "extra": {
      "eas": {
        "projectId": "e6e5b944-ee40-4251-8b89-ff8a3e733ec2"
      }
    }
  }
}
