{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Expo)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web"],
      "cwd": "Frontend",
      "port": 8081
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "Backend",
      "port": 8000
    }
  ]
}
