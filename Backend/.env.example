COIN_PACK_100_KES=99
COIN_PACK_500_KES=499
COIN_PACK_1000_KES=899
COIN_PACK_100_USD=0.99
COIN_PACK_500_USD=4.99
COIN_PACK_1000_USD=8.99

# CORS
CORS_ORIGINS=["http://localhost:8081","https://yourdomain.com"]

#FOR PRODUCTION
